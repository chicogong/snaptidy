# SQLite databases (scan index, dedup cache)
*.db

# CSV data files (duplicates, move plans, logs)
*.csv

# HTML reports (album report, thumbnail preview)
*.html

# JSON manifests and checkpoints
photo_index.json
import_checkpoint.json
import_report.json
plan_manifest.json
quick_*.json
privacy_report.json

# AppleScript fallback files
*.applescript

# Undo records
undo_records/

# Review folders (moved duplicates)
review/

# Test data (large test photos, generated artifacts)
test_data/
